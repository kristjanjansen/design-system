{
  "name": "system-design",
  "version": "3.0.0",
  "description": "Modern React design system with oklch colors, CSS custom properties, multi-brand theming, and native web platform features.",
  "homepage": "https://github.com/kristjanjansen/system-design#readme",
  "bugs": {
    "url": "https://github.com/kristjanjansen/system-design/issues"
  },
  "license": "MIT",
  "author": "Kristjan Jansen <kristjan.jansen@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristjanjansen/system-design.git"
  },
  "files": [
    "dist",
    "src",
    "CLAUDE.md",
    "DESIGN.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json",
    "./css/style.css": "./dist/style.css",
    "./css/variables.css": "./dist/variables.css",
    "./css/themes.css": "./dist/themes/index.css",
    "./css/*.css": "./dist/components/*/*.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@tsdown/css": "^0.21.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "@vitejs/plugin-react": "^6.0.1",
    "bumpp": "^11.0.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "packageManager": "npm@11.4.1"
}
